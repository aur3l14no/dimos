+DeskewedLidarSnapshot LaserMapping::get_deskewed_lidar_snapshot() const {
+    DeskewedLidarSnapshot snapshot;
+    if (!feats_down_world || feats_down_world->empty()) return snapshot;
+
+    M3D world_R_lidar;
+    V3D world_t_lidar;
+    get_world_lidar_pose(world_R_lidar, world_t_lidar);
+
+    snapshot.cloud.reset(new PointCloudXYZI(feats_down_world->size(), 1));
+    for (size_t i = 0; i < feats_down_world->size(); ++i) {
+        const PointType &point_world = feats_down_world->points[i];
+        const V3D world_point(point_world.x, point_world.y, point_world.z);
+        const V3D lidar_point = world_R_lidar.transpose() * (world_point - world_t_lidar);
+        PointType &point_lidar = snapshot.cloud->points[i];
+        point_lidar = point_world;
+        point_lidar.x = lidar_point.x();
+        point_lidar.y = lidar_point.y();
+        point_lidar.z = lidar_point.z();
+    }
+
+    custom_messages::Odometry &odometry = snapshot.lidar_odometry;
+    odometry = odomAftMapped;
+    odometry.header.stamp = get_ros_time(time_current);
+
+    const Eigen::Quaterniond world_q_lidar(world_R_lidar);
+
+    odometry.pose.pose.position.x = world_t_lidar.x();
+    odometry.pose.pose.position.y = world_t_lidar.y();
+    odometry.pose.pose.position.z = world_t_lidar.z();
+    odometry.pose.pose.orientation.x = world_q_lidar.x();
+    odometry.pose.pose.orientation.y = world_q_lidar.y();
+    odometry.pose.pose.orientation.z = world_q_lidar.z();
+    odometry.pose.pose.orientation.w = world_q_lidar.w();
+    // The new contract covers pose and stamp. Keep the estimator's existing
+    // twist convention; covariance is copied unchanged from odomAftMapped.
+    set_twist(odometry.twist.twist);
+    return snapshot;
+}
 std::vector<double> LaserMapping::get_world_quat() const {
